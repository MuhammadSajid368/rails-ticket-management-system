<h1>Edit Ticket</h1>
<%= form_with model: @ticket, local: true do |form| %>
  <div class="form-group">
    <%= form.label :title %>
    <%= form.text_field :title, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= form.label :description %>
    <%= form.text_area :description, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= form.label :status %>
    <%= form.select :status, ["Open", "In Progress", "Closed"], {}, class: "form-control" %>
  </div>
  <div class="form-group">
    <%= form.label :user_id, "Assign to" %>
    <%= form.collection_select :user_id, User.all, :id, :email, { include_blank: "Select a user" }, class: "form-control" %>
  </div>

  <!-- Assign to Me Button -->
  <div class="form-group mb-2 mt-1">
    <button type="button" class="btn btn-primary btn-sm" id="assign_to_me">Assign to Me</button>
  </div>


  <div class="form-group">
    <%= form.submit "Update Ticket", class: "btn btn-success" %>
  </div>
<% end %>
<script>
  document.addEventListener("DOMContentLoaded", function () {
    document.getElementById("assign_to_me").addEventListener("click", function () {
      document.getElementById("ticket_user_id").value = "<%= current_user.id %>";
    });
  });
</script>

