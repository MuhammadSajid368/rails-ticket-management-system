<h1 class="mb-4 text-center">Welcome to Ticket Managemnt App</h1>

<div class="alert alert-info">
  <% if user_signed_in? %>
    <strong>Signed in as:</strong> <%= current_user.email %>
  <% else %>
    <strong>You are not signed in.</strong>
  <% end %>
</div>

<div class="d-flex justify-content-between align-items-center">
  <h2>All Tickets</h2>
  <%= link_to "Create New Ticket", new_ticket_path, class: "btn btn-primary" %>
</div>

<table class="table table-striped table-hover mt-3">
  <thead class="table-dark">
    <tr>
      <th>Title</th>
      <th>Description</th>
      <th>Status</th>
      <th>Assigned To</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @tickets.each do |ticket| %>
      <tr>
        <td><%= ticket.title %></td>
        <td><%= truncate(ticket.description, length: 50) %></td>
        <td>
          <span class="badge 
            <%= ticket.status == 'Open' ? 'bg-success' : ticket.status == 'In Progress' ? 'bg-warning' : 'bg-danger' %>">
            <%= ticket.status %>
          </span>
        </td>
        <td>
          <%= ticket.user.present? ? ticket.user.email : '<span class="text-muted">Unassigned</span>'.html_safe %>
        </td>
        <td>
        <div class="d-flex gap-2">
          <%= link_to "Show", ticket_path(ticket), class: "btn btn-info btn-sm" %>
          <%= link_to "Edit", edit_ticket_path(ticket), class: "btn btn-warning btn-sm" %>
          <%= button_to "Delete", ticket_path(ticket), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-danger btn-sm" %>
        </div>
      </td>
      
      </tr>
    <% end %>
  </tbody>
</table>
